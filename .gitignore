# PyCharm files
.idea/

# Compiled python modules.
*.pyc

# Setuptools distribution folder.
/dist/

# Python egg metadata, regenerated from source files by setuptools.
/*.egg-info

# Mac OS
.DS_Store

# Others
venv/
*.log
*.npy

# Curated face dataset — lives at salvacarrion/face-detection on HF Hub.
# Only repopulated locally by the maintainer when rebuilding the HF dataset.
datasets/

# Preprocessed NPY bundles produced by tools/prepare_data.py.
# Re-derivable from the HF dataset, no need to track.
data/

# Bootstrap negative pool (Caltech-256 crops, generated by tools/build_dataset.py caltech).
# Maintainer-only; superseded by data/<R>/caltech_pool.npy in the normal flow.
bootstrap/
